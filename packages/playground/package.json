{
  "name": "playground",
  "version": "0.1.0",
  "description": "Embeddable editor playground for the aui AsyncAPI renderer",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/playground.cjs.js",
  "module": "./dist/playground.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/playground.es.js",
      "require": "./dist/playground.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "prepublishOnly": "npm run build:lib"
  },
  "dependencies": {
    "@asyncapi/parser": "^3.6.0",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@uiw/codemirror-themes-all": "^4.25.11",
    "@uiw/react-codemirror": "^4.25.11",
    "aui": "*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^5.0.3"
  }
}
