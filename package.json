{
  "name": "aui-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build:lib": "npm run build --workspace=packages/aui",
    "dev:lib": "npm run dev --workspace=packages/aui",
    "playground": "concurrently \"npm run watch --workspace=packages/aui\" \"npm run dev --workspace=packages/playground\"",
    "storybook": "npm run storybook --workspace=packages/aui"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
